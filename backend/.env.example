# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=HeatShield AI
VERSION=1.0.0

# Security
SECRET_KEY=generate-with-openssl-rand-hex-32-or-use-secrets-manager
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heatshield

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ISRO Bhuvan API
BHUVAN_API_KEY=your-bhuvan-api-key
BHUVAN_API_URL=https://bhuvan.nrsc.gov.in/api

# Weather Data
IMD_API_URL=https://imd.gov.in/api

# AI/ML Settings
MODEL_PATH=./models
BATCH_SIZE=32

# Satellite Data
LANDSAT_API_URL=https://earthexplorer.usgs.gov/api
SENTINEL_API_URL=https://scihub.copernicus.eu/apihub
